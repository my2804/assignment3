@using assignment3.ViewModels
@model StudentFormModel
@{
    ViewData["Title"] = "Create Student";
}

<h2>Create Student</h2>

<div class="col-md-6">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MajorId" class="form-label">Major</label>
            <select asp-for="MajorId" asp-items="Model.Majors" class="form-select">
                <option value="">— None —</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="MentorId" class="form-label">Mentor</label>
            <select asp-for="MentorId" asp-items="Model.Mentors" class="form-select">
                <option value="">— None —</option>
            </select>
            <small class="text-muted">All existing students are listed as potential mentors.</small>
        </div>

        <h5>Contact (optional)</h5>

        <div class="mb-3">
            <label asp-for="PhoneNumber" class="form-label">Phone</label>
            <input asp-for="PhoneNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Address" class="form-label">Address</label>
            <input asp-for="Address" class="form-control" />
        </div>

        <h5>Enroll Courses</h5>
        @foreach (var course in Model.AllCourses)
        {
            <div class="form-check">
                <input type="checkbox" name="SelectedCourseIds" value="@course.CourseId"
                       class="form-check-input"
                       id="course_@course.CourseId"
                       @(Model.SelectedCourseIds.Contains(course.CourseId) ? "checked" : "") />
                <label class="form-check-label" for="course_@course.CourseId">
                    @course.Title
                </label>
            </div>
        }
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>