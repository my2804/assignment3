@model Student
@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>

<a asp-action="Index" class="btn btn-secondary mb-3">Back to List</a>

<div class="card p-4 border-danger col-md-5">
    <h5 class="text-danger">Confirm deletion</h5>
    <table class="table table-borderless">
        <tr><th>Student ID</th><td>@Model.StudentId</td></tr>
        <tr><th>Name</th><td>@Model.Name</td></tr>
        <tr><th>Major</th><td>@(Model.Major?.Name ?? "—")</td></tr>
        <tr><th>Mentor</th><td>@(Model.Mentor?.Name ?? "—")</td></tr>
        <tr><th>Courses (count)</th><td>@Model.Courses.Count</td></tr>
        <tr><th>Mentees (count)</th><td>@Model.Mentees.Count</td></tr>
    </table>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.StudentId" />
        <button type="submit" class="btn btn-danger">Yes, delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>